<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level [%logger{36}] [%M (line:%L)] [%t]: %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="DEBUG">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>

<!--
personal reminder:
logger levels: (loggers of level less or equal than the one set are shown)

1 OFF
2 FATAL
3 ERROR
4 WARN
5 INFO
6 DEBUG
7 TRACE
8 ALL

-->